<VirtualHost *:8081>
    ServerName 10.52.83.10
    ServerAlias 100.111.213.115

    ProxyPreserveHost On
    RequestHeader set X-Forwarded-Proto "http"

    Alias /static/ /opt/warehouse_config/staticfiles/
    <Directory /opt/warehouse_config/staticfiles/>
        Require all granted
    </Directory>

    # Apache serves only collected static assets. Root-level PWA endpoints
    # (/manifest.webmanifest and /service-worker.js) must continue to proxy
    # to Django/Gunicorn so Django can set the expected content type/headers.
    ProxyPass /static/ !
    ProxyPass / http://127.0.0.1:8001/
    ProxyPassReverse / http://127.0.0.1:8001/

    ErrorLog ${APACHE_LOG_DIR}/warehouse_error.log
    CustomLog ${APACHE_LOG_DIR}/warehouse_access.log combined
</VirtualHost>
