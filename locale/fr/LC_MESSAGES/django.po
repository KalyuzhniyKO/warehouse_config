msgid "Комірки, стелажі та зони складу."
msgstr "Bins, racks, and warehouse zones."

msgid "Контроль"
msgstr "Contrôle"

msgid "Контроль і звіти"
msgstr "Contrôle et rapports"

msgid "Місця зберігання товарів."
msgstr "Goods storage places."

msgid "Назад до списку"
msgstr "Retour à la liste"

msgid "Налаштування принтерів етикеток."
msgstr "Label printer settings."

msgid "Немає залишків за вибраними фільтрами."
msgstr "Aucun stock pour les filtres sélectionnés."

msgid "Немає рухів за вибраними фільтрами."
msgstr "Aucun mouvement pour les filtres sélectionnés."

msgid "Немає інвентаризацій."
msgstr "Aucun inventaire."

msgid "Нова операція"
msgstr "Nouvelle opération"

msgid "Оберіть потрібну дію для щоденної складської роботи."
msgstr "Choisissez une action pour le travail quotidien en entrepôt."

msgid "Одиниці для обліку кількості."
