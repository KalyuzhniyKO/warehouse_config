msgid "Проведіть або перегляньте перерахунок складу."
msgstr "Perform or review a warehouse count."

msgid "Підрозділи та контакти для видач."
msgstr "Departments and contacts for issues."

msgid "Складські операції"
msgstr "Opérations d'entrepôt"

msgid "Створіть перший запис."
msgstr "Créez le premier enregistrement."

msgid "Товари, матеріали та їхні коди."
msgstr "Goods, materials, and their codes."

msgid "Формати та шаблони для друку."
msgstr "Print formats and templates."

msgid "Перегляньте інвентаризації складу."
msgstr "Consultez les inventaires de l'entrepôt."
