DJANGO_SECRET_KEY=
# Only for local development; do not enable DEBUG in production.
DJANGO_DEBUG=False
# Replace your-server-ip with the deployment IP or domain.
# Do not commit real production secrets, passwords, tokens, or private infrastructure addresses.
DJANGO_ALLOWED_HOSTS=your-server-ip,localhost,127.0.0.1
# Django 4+ requires each CSRF trusted origin to include http:// or https://.
DJANGO_CSRF_TRUSTED_ORIGINS=http://your-server-ip:8081
DJANGO_LANGUAGE_CODE=uk
DJANGO_TIME_ZONE=Europe/Kyiv

# Production with HTTPS:
# DJANGO_SESSION_COOKIE_SECURE=True
# DJANGO_CSRF_COOKIE_SECURE=True
# DJANGO_SECURE_SSL_REDIRECT=True

# Production MySQL persistent connections:
DJANGO_DB_CONN_MAX_AGE=60

# Production password validators:
DJANGO_ENABLE_PASSWORD_VALIDATORS=True

DB_ENGINE=django.db.backends.mysql
DB_NAME=warehouse_db
DB_USER=warehouse_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=3306
